# Gostera environment variables.
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
#
# You need AT LEAST ONE AI provider below for the app to generate anything.
# Each key is independent: Gemini works without Claude keys and vice versa.

# ── Google Gemini (free tier — recommended starting point) ───────────────────
# Free key, no credit card: https://aistudio.google.com  →  "Get API key"
# Enables the "Gemini 3.5 Flash (FREE)" model in Generate, Discuss and Agent modes.
GEMINI_API_KEY=

# ── Claude — option 1: subscription (Pro/Max, no per-token billing) ──────────
# Generate once with:  claude setup-token   (needs Claude Code + a Pro/Max plan)
# IMPORTANT: define this key ONCE only. A duplicate line later in the file
# silently overrides an earlier one and is an easy way to end up with a 401.
CLAUDE_CODE_OAUTH_TOKEN=

# ── Claude — option 2: metered API key (used only if the token above is empty) ─
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── GitHub push (optional) ───────────────────────────────────────────────────
# Only needed for the "Push to GitHub" button. Create an OAuth App at
# https://github.com/settings/developers and set its callback URL to:
#   http://<your-host>:3000/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
